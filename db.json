  "temoignages": [
    {
      "id": 1,
      "naufrageId": 1,
      "nom": "Margaret Brown",
      "age": 44,
      "nationalite": "Américaine",
      "statut": "Survivante",
      "temoignage": "La nuit était glaciale. Nous entendions les cris de ceux qui se noyaient dans l'eau noire. Les canots étaient insuffisants pour tout le monde.",
      "audio": "/audios/temoignage_margaret.mp3"
    },
    {
      "id": 2,
      "naufrageId": 1,
      "nom": "Jack Thayer",
      "age": 17,
      "nationalite": "Américaine",
      "statut": "Survivant",
      "temoignage": "J'ai sauté à l'eau et nagé vers un canot retourné. Le navire s'est brisé en deux avant de couler.",
      "audio": "/audios/temoignage_thayer.mp3"
    },
    {
      "id": 3,
      "naufrageId": 2,
      "nom": "Mamadou Diop",
      "age": 42,
      "nationalite": "Sénégalaise",
      "statut": "Survivant",
      "temoignage": "Le bateau a chaviré en quelques minutes. J'ai passé plusieurs heures dans l'océan avant d'être secouru par des pêcheurs.",
      "audio": "/audios/temoignage_mamadou.mp3"
    },
    {
      "id": 4,
      "naufrageId": 2,
      "nom": "Fatou Sow",
      "age": 28,
      "nationalite": "Sénégalaise",
      "statut": "Survivante",
      "temoignage": "Tout est allé très vite. J'ai perdu mon mari et mes deux enfants cette nuit-là. Je suis la seule de ma famille à avoir survécu.",
      "audio": "/audios/temoignage_fatou.mp3"
    },
    {
      "id": 5,
      "naufrageId": 3,
      "nom": "Juan Santos",
      "age": 36,
      "nationalite": "Philippine",
      "statut": "Survivant",
      "temoignage": "L'explosion et l'incendie ont été immédiats après la collision. Il faisait noir et les flammes se propageaient partout.",
      "audio": "/audios/temoignage_juan.mp3"
    },
    {
      "id": 6,
      "naufrageId": 4,
      "nom": "Eva Dorn",
      "age": 31,
      "nationalite": "Allemande",
      "statut": "Survivante",
      "temoignage": "Nous fuyions les combats avec nos enfants. Quand les torpilles ont frappé, la panique était totale. L'eau était tellement froide.",
      "audio": "/audios/temoignage_eva.mp3"
    },
    {
      "id": 7,
      "naufrageId": 6,
      "nom": "Charles Lauriat",
      "age": 39,
      "nationalite": "Américaine",
      "statut": "Survivant",
      "temoignage": "Le navire a coulé en 18 minutes seulement. Personne n'avait eu le temps de comprendre ce qui se passait.",
      "audio": "/audios/temoignage_lauriat.mp3"
    },
    {
      "id": 8,
      "naufrageId": 7,
      "nom": "Anu Mägi",
      "age": 24,
      "nationalite": "Estonienne",
      "statut": "Survivante",
      "temoignage": "La mer était déchaînée. J'ai réussi à attraper un radeau de sauvetage. Beaucoup de personnes autour de moi ont été emportées par les vagues.",
      "audio": "/audios/temoignage_anu.mp3"
    },
    {
      "id": 9,
      "naufrageId": 8,
      "nom": "Sofia Rinaldi",
      "age": 52,
      "nationalite": "Italienne",
      "statut": "Survivante",
      "temoignage": "Le capitaine nous a dit de rester calmes, que c'était une panne technique. Pendant ce temps le navire penchait de plus en plus.",
      "audio": "/audios/temoignage_sofia.mp3"
    },
    {
      "id": 10,
      "naufrageId": 9,
      "nom": "Kim Ji-young",
      "age": 17,
      "nationalite": "Sud-Coréenne",
      "statut": "Survivante",
      "temoignage": "Le message officiel nous demandait de rester à nos places. Ceux qui ont obéi n'ont pas survécu. J'ai désobéi et je suis en vie.",
      "audio": "/audios/temoignage_kimji.mp3"
    }
  ],

